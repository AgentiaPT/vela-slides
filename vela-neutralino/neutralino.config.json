{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "ai.vela.desktop",
  "version": "0.2.0",
  "applicationName": "Vela Slides",
  "description": "Vela Slides",
  "author": "Vela",
  "defaultMode": "window",
  "documentRoot": "/resources/",
  "url": "/index.html",
  "enableServer": true,
  "enableNativeAPI": true,
  "enableExtensions": true,
  "extensions": [
    {
      "id": "ai.vela.agent",
      "commandLinux": "${NL_PATH}/extensions/agent/vela-agent",
      "commandDarwin": "${NL_PATH}/extensions/agent/vela-agent",
      "commandWindows": "${NL_PATH}/extensions/agent/vela-agent.exe"
    }
  ],
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": true
  },
  "nativeAllowList": [
    "app.*",
    "window.*",
    "debug.log",
    "os.showFolderDialog",
    "os.getEnv",
    "filesystem.readFile",
    "filesystem.writeFile",
    "filesystem.readDirectory",
    "filesystem.createDirectory",
    "filesystem.getStats",
    "filesystem.createWatcher",
    "filesystem.removeWatcher",
    "filesystem.remove",
    "filesystem.move",
    "storage.*",
    "events.*",
    "extensions.getStats"
  ],
  "modes": {
    "window": {
      "title": "Vela Slides",
      "width": 1400,
      "height": 900,
      "minWidth": 960,
      "minHeight": 600,
      "center": true,
      "fullScreen": false,
      "alwaysOnTop": false,
      "icon": "/resources/icons/vela.png",
      "enableInspector": false,
      "borderless": false,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "exitProcessOnClose": true
    }
  },
  "cli": {
    "binaryName": "vela",
    "resourcesPath": "/resources/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/resources/js/neutralino.js",
    "binaryVersion": "6.3.0",
    "clientVersion": "6.1.0"
  }
}
