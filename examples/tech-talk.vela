        {
          "id": "5615eb27",
          "title": "Architecture",
          "notes": "",
          "comments": [],
          "status": "done",
          "importance": "should",
          "order": 0,
          "slides": [
            {
              "title": "The Architecture",
              "bg": "#0c1a2e",
              "bgGradient": "linear-gradient(160deg, #0c1a2e 0%, #0f1d2e 100%)",
              "color": "#e2e8f0",
              "accent": "#06b6d4",
              "padding": "36px 48px",
              "duration": 90,
              "blocks": [
                {
                  "type": "heading",
                  "text": "Edge-First Request Architecture",
                  "size": "2xl",
                  "icon": "Network"
                },
                {
                  "type": "spacer",
                  "h": 8
                },
                {
                  "type": "grid",
                  "columns": 2,
                  "gap": 16,
                  "items": [
                    {
                      "blocks": [
                        {
                          "type": "flow",
                          "items": [
                            {
                              "icon": "Smartphone",
                              "text": "Client"
                            },
                            {
                              "icon": "Server",
                              "text": "Edge Node"
                            },
                            {
                              "icon": "Database",
                              "text": "Cache / Origin"
                            },
                            {
                              "icon": "ArrowLeft",
                              "text": "Response"
                            }
                          ],
                          "connector": "arrow"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "type": "cycle",
                          "items": [
                            {
                              "label": "Request",
                              "icon": "📡"
                            },
                            {
                              "label": "Cache",
                              "icon": "💾"
                            },
                            {
                              "label": "Validate",
                              "icon": "✅"
                            },
                            {
                              "label": "Replicate",
                              "icon": "🔄"
                            }
                          ],
                          "centerLabel": "Edge"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "spacer",
                  "h": 8
                },
                {
                  "type": "callout",
                  "text": "Edge nodes intercept requests within 50ms of the user. Cache hits bypass origin entirely — reducing P99 latency from 820ms to 47ms in production.",
                  "icon": "Zap",
                  "bg": "#06b6d415",
                  "border": "#06b6d440"
                }
              ]
            }
          ],
          "createdAt": "2026-06-01T01:08:11.742Z"
        },
        {
          "id": "7e474243",
          "title": "Implementation",
          "notes": "",
          "comments": [],
          "status": "done",
          "importance": "should",
          "order": 0,
          "slides": [
            {
              "title": "Code Example",
              "bg": "#0a1628",
              "bgGradient": "linear-gradient(135deg, #0a1628 0%, #0d1f30 100%)",
              "color": "#e2e8f0",
              "accent": "#22d3ee",
              "padding": "36px 48px",
              "duration": 90,
              "blocks": [
                {
                  "type": "heading",
                  "text": "Edge Function Handler",
                  "size": "2xl",
                  "icon": "Code"
                },
                {
                  "type": "spacer",
                  "h": 8
                },
                {
                  "type": "code",
                  "language": "typescript",
                  "text": "export default async function handler(req: Request) {\n  const cacheKey = `edge:${req.url}`;\n  const cached = await kv.get(cacheKey);\n\n  if (cached && !isStale(cached.timestamp)) {\n    return new Response(cached.body, {\n      headers: { 'X-Edge-Cache': 'HIT' }\n    });\n  }\n\n  const origin = await fetch(req.url, { cf: { cacheTtl: 300 } });\n  await kv.put(cacheKey, await origin.clone().text());\n  return origin;\n}"
                },
                {
                  "type": "spacer",
                  "h": 8
                },
                {
                  "type": "text",
                  "text": "Each edge function runs in an isolated V8 runtime with <5ms cold start. The KV store replicates across all 280+ edge locations within seconds.",
                  "size": "md",
                  "color": "#94a3b8"
                }
              ]
            }
          ],
          "createdAt": "2026-06-01T01:08:11.742Z"
        },
