                    {
                      "title": "Identify Hot Paths",
                      "text": "Profile your API to find cacheable, latency-sensitive endpoints"
                    },
                    {
                      "title": "Deploy Edge Functions",
                      "text": "Start with read-heavy routes — cache invalidation is simpler there"
                    },
                    {
                      "title": "Measure and Iterate",
                      "text": "Track cache hit rates, tail latencies, and error budgets per region"
