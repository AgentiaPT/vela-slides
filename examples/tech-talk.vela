                {
                  "type": "checklist",
                  "items": [
                    {
                      "text": "Edge computing eliminates the latency tax — serve from where your users are",
                      "status": "done"
                    },
                    {
                      "text": "Cache-first architecture reduces origin load by 90%+ and improves resilience",
                      "status": "done"
                    },
                    {
                      "text": "Isolated V8 runtimes give you full programmability without cold start penalties",
                      "status": "done"
                    },
                    {
                      "text": "Graceful fallback patterns ensure availability even when origin is unreachable",
                      "status": "partial"
                    }
                  ],
