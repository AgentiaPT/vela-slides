                          "icon": "Monitor",
                          "color": "#60a5fa"
                        },
                        {
                          "type": "text",
                          "text": "Claude.ai blocks native fullscreen. Click the **⛵ icon** to get a bookmarklet for true browser fullscreen.",
                          "size": "sm",
                          "color": "#94a3b8"
                        }
                      ],
                      "padding": "16px",
                      "bg": "#1e293b",
                      "borderRadius": "8px"
