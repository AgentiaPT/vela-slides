                          "icon": "Sparkles",
                          "iconColor": "#a78bfa"
                        },
                        {
                          "type": "spacer",
                          "h": 8
                        },
                        {
                          "type": "text",
                          "text": "Install the Vela skill in any Claude Project. Ask Claude to create decks from any topic — it generates compact JSON, validates, and assembles the artifact automatically.",
                          "size": "sm",
                          "color": "#94a3b8"
