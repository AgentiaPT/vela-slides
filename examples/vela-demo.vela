          "slides": [
            {
              "title": "Student Mode",
              "duration": 75,
              "padding": "48px 64px",
              "bg": "linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%)",
              "color": "#e2e8f0",
              "accent": "#a78bfa",
              "gap": 24,
              "blocks": [
                {
                  "type": "badge",
                  "text": "NEW IN v10",
                  "icon": "Sparkles",
                  "color": "#a78bfa",
                  "bg": "#a78bfa15",
                  "border": "#a78bfa40"
                },
                {
                  "type": "heading",
                  "text": "Student Mode 🎓",
                  "size": "3xl",
                  "icon": "GraduationCap",
                  "iconColor": "#a78bfa"
                },
                {
                  "type": "text",
                  "text": "Vera becomes a teaching assistant in presenter mode. Ask questions about any slide — get streaming answers with SVG diagrams, right inside fullscreen.",
                  "size": "lg",
                  "color": "#c7d2fe"
                },
                {
                  "type": "spacer",
                  "h": 12
                },
                {
                  "type": "icon-row",
                  "items": [
                    {
                      "icon": "MessageSquare",
                      "text": "Per-slide Q&A with history"
                    },
                    {
                      "icon": "Cpu",
                      "text": "Haiku 4.5 + prompt caching"
                    },
                    {
                      "icon": "Zap",
                      "text": "N+1 prefetch for instant answers"
                    },
                    {
                      "icon": "PenTool",
                      "text": "SVG diagrams in responses"
                    }
                  ],
                  "cols": 2,
                  "gap": 16,
                  "iconBg": "#1e1b4b",
                  "iconColor": "#a78bfa"
                },
                {
                  "type": "spacer",
                  "h": 12
                },
                {
                  "type": "callout",
                  "text": "Try it: enter fullscreen, click 🎓 in the top bar. Ask Vera anything about the current slide — she teaches with context.",
                  "icon": "Zap",
                  "bg": "#a78bfa12",
                  "border": "#a78bfa30",
                  "color": "#e0e7ff"
                }
              ]
            },
            {
              "title": "Gallery View & Smart Merge",
              "duration": 60,
              "padding": "48px 64px",
              "bg": "#0f172a",
              "color": "#e2e8f0",
              "accent": "#a78bfa",
              "gap": 20,
              "blocks": [
                {
                  "type": "heading",
                  "text": "Gallery View & Smart Merge",
                  "size": "2xl",
                  "icon": "LayoutGrid",
                  "iconColor": "#a78bfa"
                },
                {
                  "type": "text",
                  "text": "Two new ways to navigate and manage your decks — visual sorting and conflict-free updates.",
                  "size": "md",
                  "color": "#94a3b8"
                },
                {
                  "type": "spacer",
                  "h": 12
                },
                {
                  "type": "grid",
                  "cols": 2,
                  "gap": 20,
                  "items": [
                    {
                      "blocks": [
                        {
                          "type": "heading",
                          "text": "Gallery View 🗂",
                          "size": "lg",
                          "icon": "Grid3x3",
                          "iconColor": "#a78bfa"
                        },
                        {
                          "type": "spacer",
                          "h": 8
                        },
                        {
                          "type": "text",
                          "text": "Slide sorter with real thumbnails. **Drag-and-drop** reorder, 7 zoom levels, per-module color bars. Press **G** in fullscreen.",
                          "size": "sm",
                          "color": "#94a3b8"
                        }
                      ],
                      "padding": "20px",
                      "bg": "#1e293b",
                      "borderRadius": "12px"
                    },
                    {
                      "blocks": [
                        {
                          "type": "heading",
                          "text": "Smart Merge 🔀",
                          "size": "lg",
                          "icon": "GitMerge",
                          "iconColor": "#a78bfa"
                        },
                        {
                          "type": "spacer",
                          "h": 8
                        },
                        {
                          "type": "text",
                          "text": "Detects new embedded deck versions. Per-item conflict resolution — **Keep Mine**, **Use New**, or **Keep Both**.",
                          "size": "sm",
                          "color": "#94a3b8"
                        }
                      ],
                      "padding": "20px",
                      "bg": "#1e293b",
                      "borderRadius": "12px"
                    }
                  ]
                },
                {
                  "type": "spacer",
                  "h": 12
                },
                {
                  "type": "flow",
                  "items": [
                    {
                      "icon": "Upload",
                      "label": "New Version"
                    },
                    {
                      "icon": "GitCompare",
                      "label": "Detect Changes"
                    },
                    {
                      "icon": "Users",
                      "label": "Resolve"
                    },
                    {
                      "icon": "CheckCircle",
