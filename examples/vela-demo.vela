    {
      "id": "5a7de0e1",
      "title": "What's New — v12",
      "collapsed": false,
      "items": [
        {
          "id": "b9191465",
          "title": "v12 Features",
          "notes": "Student mode, studyNotes, copy & reveal features",
          "comments": [
            {
              "id": "c_aad7a641",
              "text": "The hero feature for the LinkedIn announcement",
              "anchor": null,
              "blockIndex": null,
              "status": "open",
              "createdAt": "2026-04-01T13:39:40.829Z",
              "resolvedAt": null
            }
          ],
          "status": "done",
          "importance": "must",
          "order": 0,
          "slides": [
            {
              "title": "Student Mode & Study Notes",
              "duration": 75,
              "padding": "48px 64px",
              "bg": "linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%)",
              "color": "#e2e8f0",
              "accent": "#a78bfa",
              "gap": 24,
              "blocks": [
                {
                  "type": "badge",
                  "text": "NEW IN v12",
                  "icon": "Sparkles",
                  "color": "#a78bfa",
                  "bg": "#a78bfa15",
                  "border": "#a78bfa40"
                },
                {
                  "type": "heading",
                  "text": "Student Mode 🎓",
                  "size": "3xl",
                  "icon": "GraduationCap",
                  "iconColor": "#a78bfa"
                },
                {
                  "type": "text",
                  "text": "Vera becomes a teaching assistant in presenter mode. Slides can embed **studyNotes** — offline-first markdown with diagrams, follow-up questions, and a glossary for Kindle-style X-Ray term popups.",
                  "size": "lg",
                  "color": "#c7d2fe"
                },
                {
                  "type": "spacer",
                  "h": 12
                },
                {
                  "type": "icon-row",
                  "items": [
                    {
                      "icon": "BookOpen",
                      "text": "Offline studyNotes — zero API calls"
                    },
                    {
                      "icon": "Microscope",
                      "text": "X-Ray glossary with term popups"
                    },
                    {
                      "icon": "HelpCircle",
                      "text": "Pre-authored follow-up questions"
                    },
                    {
                      "icon": "PenTool",
                      "text": "Inline SVG diagrams in notes"
                    }
                  ],
                  "cols": 2,
                  "gap": 16,
                  "iconBg": "#1e1b4b",
                  "iconColor": "#a78bfa"
                },
                {
                  "type": "spacer",
                  "h": 12
                },
                {
                  "type": "callout",
                  "text": "This slide has studyNotes attached — look for the 🎓 marker. Enter fullscreen, click 🎓 to see offline content with glossary terms you can tap to explore.",
                  "icon": "Zap",
                  "bg": "#a78bfa12",
                  "border": "#a78bfa30",
                  "color": "#e0e7ff"
                }
              ],
              "studyNotes": {
                "text": "**Student Mode** transforms Vela into an interactive learning tool. Each slide can embed pre-authored study content that renders with *zero API calls*.\n\nThe key insight: slides contain the presentation narrative, while [studyNotes](#studynotes) contain the deeper learning material. This separation means presenters see clean slides, while students get rich, offline-first study content.\n\nStudy notes support **markdown** formatting, inline [glossary](#glossary) terms (tap to see definitions), and follow-up questions that become interactive when a live API channel is available.",
                "questions": [
                  "Why is offline-first important for training environments?",
                  "How do glossary popups improve comprehension compared to footnotes?",
                  "When would you use studyNotes vs. live Vera Teacher mode?"
                ],
                "glossary": {
                  "studynotes": {
                    "definition": "Pre-authored markdown content embedded in slides that renders offline. Includes text, SVG diagrams, follow-up questions, and a glossary for X-Ray term popups."
                  },
                  "glossary": {
                    "definition": "A set of term definitions (max 24) that power Kindle-style X-Ray popups. Terms are linked inline using [term](#key) syntax."
                  }
                }
              }
            },
            {
              "title": "Gallery View & Smart Merge",
              "duration": 60,
              "padding": "48px 64px",
              "bg": "#0f172a",
              "color": "#e2e8f0",
              "accent": "#a78bfa",
              "gap": 20,
              "blocks": [
                {
                  "type": "heading",
                  "text": "Gallery View & Smart Merge",
                  "size": "2xl",
                  "icon": "LayoutGrid",
                  "iconColor": "#a78bfa"
                },
                {
                  "type": "text",
                  "text": "Two new ways to navigate and manage your decks — visual sorting and conflict-free updates.",
                  "size": "md",
                  "color": "#94a3b8"
                },
                {
                  "type": "spacer",
                  "h": 12
                },
                {
                  "type": "grid",
                  "cols": 2,
                  "gap": 20,
                  "items": [
                    {
                      "blocks": [
                        {
                          "type": "heading",
                          "text": "Gallery View 🗂",
                          "size": "lg",
                          "icon": "Grid3x3",
                          "iconColor": "#a78bfa"
                        },
                        {
                          "type": "spacer",
                          "h": 8
                        },
                        {
                          "type": "text",
                          "text": "Slide sorter with real thumbnails. **Drag-and-drop** reorder, 7 zoom levels, per-module color bars. Press **G** in fullscreen.",
                          "size": "sm",
                          "color": "#94a3b8"
                        }
                      ],
                      "padding": "20px",
                      "bg": "#1e293b",
                      "borderRadius": "12px"
                    },
                    {
                      "blocks": [
                        {
                          "type": "heading",
                          "text": "Smart Merge 🔀",
                          "size": "lg",
                          "icon": "GitMerge",
                          "iconColor": "#a78bfa"
                        },
                        {
                          "type": "spacer",
                          "h": 8
                        },
                        {
                          "type": "text",
                          "text": "Detects new embedded deck versions. Per-item conflict resolution — **Keep Mine**, **Use New**, or **Keep Both**.",
                          "size": "sm",
                          "color": "#94a3b8"
                        }
                      ],
                      "padding": "20px",
                      "bg": "#1e293b",
                      "borderRadius": "12px"
                    }
                  ]
                },
                {
                  "type": "spacer",
                  "h": 12
                },
                {
                  "type": "flow",
                  "items": [
                    {
                      "icon": "Upload",
                      "label": "New Version"
                    },
                    {
                      "icon": "GitCompare",
                      "label": "Detect Changes"
                    },
                    {
                      "icon": "Users",
                      "label": "Resolve"
                    },
                    {
                      "icon": "CheckCircle",
                      "label": "Merged"
                    }
                  ],
                  "connectorStyle": "arrow",
                  "arrowColor": "#a78bfa",
                  "iconBg": "#1e1b4b",
                  "labelColor": "#e2e8f0"
                }
              ]
            },
            {
              "title": "Columns Layout",
              "duration": 75,
              "padding": "48px 64px",
              "bg": "linear-gradient(135deg, #0f172a 0%, #1a1b3a 100%)",
              "color": "#e2e8f0",
              "accent": "#34d399",
              "gap": 16,
              "layout": "cols",
              "contentFlex": 3,
              "imageFlex": 2,
              "splitGap": 28,
              "blocks": [
                {
                  "type": "badge",
                  "text": "NEW IN v12.36",
                  "icon": "Sparkles",
                  "color": "#34d399",
                  "bg": "#34d39915",
                  "border": "#34d39940"
                },
                {
                  "type": "heading",
                  "text": "Columns Layout 📐",
                  "size": "2xl",
                  "icon": "Columns",
                  "iconColor": "#34d399"
                },
                {
                  "type": "text",
                  "text": "Two-column slides using **L** (left) and **R** (right) block arrays — works with any block type.",
                  "size": "md",
                  "color": "#94a3b8"
                }
              ],
              "L": [
                {
                  "type": "callout",
                  "text": "Place any blocks side-by-side — text, metrics, flows, tables. Ratio control via **contentFlex / imageFlex**.",
                  "title": "Flexible Columns",
                  "icon": "LayoutGrid",
                  "bg": "#34d39912",
                  "border": "#34d39930",
                  "color": "#d1fae5"
                },
                {
                  "type": "steps",
                  "items": [
                    {
                      "title": "Set layout",
                      "text": "layout: \"cols\""
                    },
                    {
                      "title": "Add header",
                      "text": "blocks (B) = full-width"
                    },
                    {
                      "title": "Fill columns",
                      "text": "L = left, R = right"
                    }
                  ],
                  "lineColor": "#34d399",
                  "numberColor": "#34d399",
                  "titleColor": "#e2e8f0",
                  "textColor": "#94a3b8"
                }
              ],
              "R": [
                {
                  "type": "metric",
                  "value": "3:2",
                  "label": "This Slide's Ratio",
                  "size": "3xl",
                  "color": "#34d399",
                  "icon": "Columns",
                  "iconColor": "#34d399"
                },
                {
                  "type": "tag-group",
                  "items": [
                    {
                      "text": "1:1 Equal",
                      "color": "#818cf8"
                    },
                    {
                      "text": "3:2 Wide left",
                      "color": "#34d399"
                    },
                    {
                      "text": "2:3 Wide right",
                      "color": "#f59e0b"
                    },
                    {
                      "text": "4:1 Sidebar",
                      "color": "#f472b6"
                    }
                  ],
                  "variant": "outline",
                  "gap": 8
                }
              ]
            }
          ],
          "createdAt": "2026-03-23T23:14:42.516Z"
        }
