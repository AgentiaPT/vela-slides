                      "icon": "FileJson",
                      "label": "Compact",
                      "sublabel": "32% smaller"
                    },
                    {
                      "icon": "Expand",
                      "label": "Expand",
                      "sublabel": "full format"
                    },
                    {
                      "icon": "ShieldCheck",
                      "label": "Validate",
                      "sublabel": "82 checks"
                    },
                    {
                      "icon": "Package",
                      "label": "Ship",
                      "sublabel": ".jsx artifact"
                    }
                  ],
                  "connectorStyle": "arrow",
                  "arrowColor": "#34d399",
                  "iconBg": "#1e293b",
                  "labelColor": "#e2e8f0",
                  "sublabelColor": "#64748b"
