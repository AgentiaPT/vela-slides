          "slides": [
            {
              "title": "Vela Slides",
              "duration": 20,
              "padding": "48px 80px",
              "align": "center",
              "verticalAlign": "center",
              "bg": "#0f172a",
              "bgGradient": "linear-gradient(140deg, #0f172a 0%, #1e1b4b 40%, #312e81 70%, #1e3a5f 100%)",
              "color": "#f1f5f9",
              "accent": "#818cf8",
              "blocks": [
                {
