                },
                {
                  "type": "badge",
                  "text": "v10.2 · MARCH 2026",
                  "icon": "Sailboat",
                  "color": "#c4b5fd",
                  "bg": "#818cf820",
                  "border": "#818cf850"
                },
                {
                  "type": "spacer",
                  "h": 20
                },
                {
                  "type": "svg",
                  "markup": "<svg viewBox=\"0 0 48 48\" xmlns=\"http://www.w3.org/2000/svg\" width=\"48\" height=\"48\"><path d=\"M24 2 L24 44\" stroke=\"{{accent}}\" stroke-width=\"2\" stroke-linecap=\"round\"/><path d=\"M24 4 Q40 14 30 38 L24 38 Z\" fill=\"{{accent}}\" opacity=\"0.85\"/><path d=\"M24 10 Q10 18 18 38 L24 38 Z\" fill=\"{{accent}}\" opacity=\"0.4\"/><path d=\"M16 46 L32 46\" stroke=\"{{accent}}\" stroke-width=\"2\" stroke-linecap=\"round\"/></svg>",
                  "align": "center",
                  "maxWidth": "48px"
                },
                {
                  "type": "spacer",
                  "h": 16
                },
                {
                  "type": "heading",
                  "text": "Vela Slides",
                  "size": "4xl",
                  "align": "center"
                },
                {
                  "type": "spacer",
                  "h": 12
                },
                {
                  "type": "heading",
                  "text": "AI-native presentations inside Claude.ai",
                  "size": "lg",
                  "align": "center",
                  "color": "#a5b4fc"
                },
                {
                  "type": "spacer",
                  "h": 32
                },
                {
                  "type": "text",
                  "text": "Think in slides. Let AI build them.\nEvery slide in this deck demonstrates the feature it describes.",
                  "size": "lg",
                  "color": "#7c8aaf",
                  "align": "center"
                },
                {
                  "type": "spacer",
                  "h": 24
                }
              ]
            },
            {
              "title": "What is Vela?",
              "duration": 60,
              "padding": "48px 64px",
              "bg": "linear-gradient(135deg, #0f172a 0%, #1e293b 100%)",
              "color": "#e2e8f0",
              "accent": "#3b82f6",
              "blocks": [
                {
                  "type": "heading",
                  "text": "You Think. Vela Shows.",
                  "size": "3xl",
                  "icon": "Zap",
                  "iconColor": "#3b82f6"
                },
                {
                  "type": "spacer",
                  "h": 12
                },
                {
                  "type": "text",
                  "text": "Vela is a presentation engine that runs as a Claude.ai artifact. Describe your ideas in natural language — Vera, the built-in AI, turns them into structured slides. No design skills. No separate tools. Just intent to output.",
                  "size": "lg",
                  "color": "#94a3b8"
                },
                {
                  "type": "spacer",
                  "h": 24
                },
                {
                  "type": "flow",
                  "items": [
                    {
                      "icon": "Brain",
                      "label": "Your Idea"
                    },
                    {
                      "icon": "MessageSquare",
                      "label": "Describe"
                    },
                    {
                      "icon": "Cpu",
                      "label": "Vera Builds"
                    },
                    {
                      "icon": "Eye",
                      "label": "Review"
                    },
                    {
                      "icon": "Presentation",
                      "label": "Present"
                    }
                  ],
                  "connectorStyle": "arrow",
                  "arrowColor": "#3b82f6",
                  "iconBg": "#1e293b",
                  "labelColor": "#e2e8f0"
                },
                {
                  "type": "spacer",
                  "h": 24
                },
                {
                  "type": "callout",
                  "text": "Vela runs entirely inside your Claude.ai subscription. No accounts, no installs, no data leaving the artifact sandbox.",
                  "icon": "Shield",
                  "bg": "#3b82f612",
                  "border": "#3b82f630",
                  "color": "#e2e8f0"
                }
              ]
            },
            {
              "title": "By the Numbers",
              "duration": 30,
              "padding": "48px 64px",
              "bg": "#0f172a",
              "color": "#e2e8f0",
              "accent": "#3b82f6",
