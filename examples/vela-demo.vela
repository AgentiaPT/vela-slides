                        },
                        {
                          "type": "text",
                          "text": "Click any text on a slide to edit it directly — even in fullscreen. **Bold** and *italic* markdown.",
                          "size": "sm",
                          "color": "#94a3b8"
                        }
                      ],
                      "padding": "16px",
                      "bg": "#1e293b",
