        {
          "id": "fe83fe20",
          "title": "Code & Visual",
          "notes": "",
          "comments": [],
          "status": "done",
          "importance": "must",
          "order": 3,
          "slides": [
            {
              "title": "Code & Callouts",
              "duration": 60,
              "padding": "48px 64px",
              "bg": "#0f172a",
              "color": "#e2e8f0",
              "accent": "#34d399",
              "gap": 20,
              "blocks": [
                {
                  "type": "heading",
                  "text": "Code Blocks, Copy & Callout Reveal",
                  "size": "2xl",
                  "icon": "Code2",
                  "iconColor": "#34d399"
                },
                {
                  "type": "text",
                  "text": "Syntax-highlighted code with labels and a **copy** button. Callouts with **reveal** for progressive disclosure.",
                  "size": "md",
                  "color": "#94a3b8"
                },
                {
                  "type": "spacer",
                  "h": 8
                },
                {
                  "type": "code",
                  "text": "// Vela slide JSON — semantic, not visual\n{\n  \"type\": \"flow\",\n  \"items\": [\n    { \"icon\": \"Brain\", \"label\": \"Think\" },\n    { \"icon\": \"Cpu\", \"label\": \"Build\" },\n    { \"icon\": \"Eye\", \"label\": \"Review\" }\n  ],\n  \"loop\": true,\n  \"loopLabel\": \"iterate\"\n}",
                  "label": "SLIDE JSON",
                  "copy": true,
                  "size": "sm",
                  "bg": "#1e293b",
                  "color": "#e2e8f0"
                },
                {
                  "type": "spacer",
                  "h": 12
                },
                {
                  "type": "callout",
                  "text": "JSON-first means AI can reason about your slides. Vera reads, writes, and refactors this structure — no pixel-pushing.",
                  "title": "Why JSON?",
                  "icon": "Lightbulb",
                  "reveal": true,
                  "bg": "#34d39912",
                  "border": "#34d39930",
                  "color": "#e2e8f0"
                }
              ]
            },
            {
              "title": "SVG Diagrams",
              "duration": 45,
              "padding": "48px 64px",
              "bg": "#0f172a",
              "color": "#e2e8f0",
              "accent": "#60a5fa",
              "gap": 20,
              "verticalAlign": "center",
              "blocks": [
                {
                  "type": "heading",
                  "text": "Custom SVG with Theme Tokens",
                  "size": "2xl",
                  "icon": "PenTool",
                  "iconColor": "#60a5fa",
                  "align": "center"
                },
                {
                  "type": "text",
                  "text": "For diagrams that structured blocks can't express — meshes, fan-outs, custom layouts.",
                  "size": "md",
                  "color": "#94a3b8",
                  "align": "center"
                },
                {
                  "type": "spacer",
                  "h": 20
                },
                {
                  "type": "svg",
                  "markup": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 500 140\"><rect x=\"10\" y=\"40\" width=\"100\" height=\"60\" rx=\"8\" fill=\"none\" stroke=\"{{accent}}\" stroke-width=\"2\"/><text x=\"60\" y=\"75\" text-anchor=\"middle\" fill=\"{{color}}\" font-size=\"13\" font-family=\"monospace\">Skill</text><rect x=\"150\" y=\"40\" width=\"100\" height=\"60\" rx=\"8\" fill=\"none\" stroke=\"{{accent}}\" stroke-width=\"2\"/><text x=\"200\" y=\"75\" text-anchor=\"middle\" fill=\"{{color}}\" font-size=\"13\" font-family=\"monospace\">Claude</text><rect x=\"290\" y=\"40\" width=\"100\" height=\"60\" rx=\"8\" fill=\"none\" stroke=\"{{accent}}\" stroke-width=\"2\"/><text x=\"340\" y=\"75\" text-anchor=\"middle\" fill=\"{{color}}\" font-size=\"13\" font-family=\"monospace\">Artifact</text><rect x=\"430\" y=\"40\" width=\"60\" height=\"60\" rx=\"8\" fill=\"{{accent}}\" fill-opacity=\"0.15\" stroke=\"{{accent}}\" stroke-width=\"2\"/><text x=\"460\" y=\"75\" text-anchor=\"middle\" fill=\"{{accent}}\" font-size=\"13\" font-family=\"monospace\">You</text><line x1=\"110\" y1=\"70\" x2=\"150\" y2=\"70\" stroke=\"{{muted}}\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/><line x1=\"250\" y1=\"70\" x2=\"290\" y2=\"70\" stroke=\"{{muted}}\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/><line x1=\"390\" y1=\"70\" x2=\"430\" y2=\"70\" stroke=\"{{muted}}\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/><defs><marker id=\"arr\" viewBox=\"0 0 10 10\" refX=\"9\" refY=\"5\" markerWidth=\"6\" markerHeight=\"6\" orient=\"auto\"><path d=\"M 0 0 L 10 5 L 0 10 z\" fill=\"{{muted}}\"/></marker></defs></svg>",
                  "align": "center",
                  "caption": "Vela pipeline: Skill → Claude → Artifact → You",
                  "captionSize": "sm",
                  "captionColor": "#94a3b8"
                },
                {
                  "type": "spacer",
                  "h": 12
                },
                {
                  "type": "callout",
                  "text": "SVG blocks use {{accent}}, {{color}}, {{muted}}, {{bg}} tokens — they adapt to any theme automatically.",
                  "icon": "Palette",
                  "bg": "#60a5fa12",
                  "border": "#60a5fa30"
                }
              ]
            },
            {
              "title": "Image Block",
              "duration": 30,
              "padding": "48px 64px",
              "bg": "#0f172a",
              "color": "#e2e8f0",
              "accent": "#f59e0b",
