                  "align": "center"
                },
                {
                  "type": "spacer",
                  "h": 20
                },
                {
                  "type": "grid",
                  "cols": 2,
                  "gap": 24,
                  "items": [
                    {
                      "bg": "#3b82f615",
                      "border": "2px solid #3b82f640",
                      "borderRadius": "12px",
                      "padding": "24px",
                      "blocks": [
                        {
                          "type": "badge",
                          "text": "AVAILABLE NOW",
                          "icon": "Check",
                          "color": "#34d399",
                          "bg": "#34d39915",
                          "border": "#34d39940"
                        },
                        {
                          "type": "spacer",
                          "h": 8
                        },
                        {
                          "type": "heading",
                          "text": "Standalone Artifact",
                          "size": "xl",
                          "icon": "Sailboat",
                          "iconColor": "#3b82f6"
                        },
                        {
                          "type": "spacer",
                          "h": 8
                        },
                        {
                          "type": "text",
                          "text": "A standalone React artifact with Vera AI built-in. All 22+ block types, PDF vector export, branding, presenter mode — self-contained, no external dependencies.",
                          "size": "sm",
                          "color": "#94a3b8"
                        }
                      ]
                    },
                    {
                      "bg": "#a78bfa15",
                      "border": "2px solid #a78bfa40",
                      "borderRadius": "12px",
                      "padding": "24px",
                      "blocks": [
                        {
                          "type": "badge",
                          "text": "AVAILABLE NOW",
                          "icon": "Rocket",
                          "color": "#a78bfa",
                          "bg": "#a78bfa15",
                          "border": "#a78bfa40"
                        },
                        {
                          "type": "spacer",
                          "h": 8
                        },
