                {
                  "type": "spacer",
                  "h": 20
                }
              ]
            },
            {
              "title": "What to Tell Vera",
              "duration": 60,
              "padding": "48px 64px",
              "bg": "linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%)",
              "color": "#e2e8f0",
              "accent": "#60a5fa",
              "gap": 20,
              "blocks": [
                {
                  "type": "badge",
                  "text": "GET STARTED",
                  "icon": "MessageSquare",
                  "color": "#60a5fa",
                  "bg": "#60a5fa15",
                  "border": "#60a5fa40"
                },
                {
                  "type": "heading",
                  "text": "Just Tell Vera What You Need",
                  "size": "2xl",
                  "icon": "Sparkles",
                  "iconColor": "#60a5fa"
                },
                {
                  "type": "text",
                  "text": "Open the Vera chat panel and describe your deck in natural language. Here are some ideas to get started:",
                  "size": "md",
                  "color": "#94a3b8"
                },
                {
                  "type": "spacer",
                  "h": 12
                },
                {
                  "type": "grid",
                  "cols": 2,
                  "gap": 16,
                  "items": [
                    {
                      "blocks": [
                        {
                          "type": "icon",
                          "name": "GraduationCap",
                          "color": "#a78bfa",
                          "circle": true,
                          "bg": "#a78bfa20",
                          "size": "lg"
                        },
                        {
                          "type": "heading",
                          "text": "Educate",
                          "size": "md"
                        },
                        {
                          "type": "text",
                          "text": "\"Create a deck explaining how neural networks learn — from perceptrons to backpropagation\"",
                          "size": "sm",
                          "color": "#94a3b8"
                        }
                      ],
                      "padding": "16px",
                      "bg": "#1e293b",
                      "borderRadius": "10px"
                    },
                    {
                      "blocks": [
                        {
                          "type": "icon",
                          "name": "TrendingUp",
                          "color": "#34d399",
                          "circle": true,
                          "bg": "#34d39920",
                          "size": "lg"
                        },
                        {
                          "type": "heading",
                          "text": "Pitch",
                          "size": "md"
                        },
                        {
                          "type": "text",
                          "text": "\"Build a 12-slide investor pitch for an AI-powered legal assistant — TAM, traction, team, ask\"",
                          "size": "sm",
                          "color": "#94a3b8"
                        }
                      ],
                      "padding": "16px",
                      "bg": "#1e293b",
                      "borderRadius": "10px"
                    },
                    {
                      "blocks": [
                        {
                          "type": "icon",
                          "name": "Users",
                          "color": "#f59e0b",
                          "circle": true,
                          "bg": "#f59e0b20",
                          "size": "lg"
                        },
                        {
                          "type": "heading",
                          "text": "Onboard",
                          "size": "md"
                        },
                        {
                          "type": "text",
                          "text": "\"Make a team onboarding deck — values, first-week checklist, key tools, org chart, and culture\"",
                          "size": "sm",
                          "color": "#94a3b8"
                        }
                      ],
                      "padding": "16px",
                      "bg": "#1e293b",
                      "borderRadius": "10px"
                    },
                    {
                      "blocks": [
                        {
                          "type": "icon",
                          "name": "Globe",
                          "color": "#ec4899",
                          "circle": true,
                          "bg": "#ec489920",
                          "size": "lg"
                        },
                        {
                          "type": "heading",
                          "text": "Explore",
                          "size": "md"
                        },
                        {
                          "type": "text",
                          "text": "\"Present the solar system — one slide per planet with key facts, a timeline of exploration, and stunning visuals\"",
                          "size": "sm",
                          "color": "#94a3b8"
                        }
                      ],
                      "padding": "16px",
                      "bg": "#1e293b",
                      "borderRadius": "10px"
                    }
                  ]
                },
                {
                  "type": "callout",
                  "text": "Tip: Be specific about slide count, sections, and style. Vera works best with clear intent — she can always refine after the first pass.",
                  "icon": "Lightbulb",
                  "bg": "#60a5fa12",
                  "border": "#60a5fa30",
                  "color": "#e2e8f0"
                }
              ]
