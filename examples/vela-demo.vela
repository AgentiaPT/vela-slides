                  "type": "spacer",
                  "h": 12
                },
                {
                  "type": "code",
                  "text": "# One command does it all\nvela deck ship my-deck.json\n\n# Edit without opening files\nvela slide edit deck.json 3 block.2.text \"New title\"\nvela deck replace-text deck.json \"old\" \"new\"",
                  "label": "VELA CLI",
                  "size": "sm",
                  "bg": "#1e293b",
                  "color": "#e2e8f0"
                }
              ]
