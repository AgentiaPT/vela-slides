{
  "deckTitle": "Introduction to Prompt Engineering",
  "lanes": [
    {
      "title": "Core Module",
      "items": [
        {
          "title": "Prompt Engineering Fundamentals",
          "status": "done",
          "slides": [
            {
              "title": "Title Slide",
              "bg": "#022c22",
              "bgGradient": "linear-gradient(150deg, #022c22 0%, #064e3b 40%, #0f766e 100%)",
              "color": "#d1fae5",
              "accent": "#34d399",
              "padding": "48px 80px",
              "duration": 30,
              "align": "left",
              "verticalAlign": "center",
              "blocks": [
                { "type": "badge", "text": "MODULE 3", "icon": "BookOpen", "color": "#022c22", "bg": "#34d399", "border": "#34d399" },
                { "type": "spacer", "h": 16 },
                { "type": "heading", "text": "Introduction to Prompt Engineering", "size": "3xl" },
                { "type": "spacer", "h": 4 },
                { "type": "text", "text": "AI Foundations Course — Spring 2026", "size": "lg", "color": "#6ee7b7" },
                { "type": "spacer", "h": 24 },
                { "type": "icon-row", "iconColor": "#34d399", "iconBg": "#34d39920", "items": [
                  { "icon": "Clock", "text": "90 Minutes" },
                  { "icon": "Wrench", "text": "Hands-on" },
                  { "icon": "Award", "text": "Certificate" }
                ]}
              ]
            },
            {
              "title": "Learning Objectives",
              "bg": "#0c2119",
              "bgGradient": "linear-gradient(160deg, #0a1f1a 0%, #112e24 100%)",
              "color": "#d1fae5",
              "accent": "#10b981",
              "padding": "36px 48px",
              "duration": 60,
              "blocks": [
                { "type": "heading", "text": "Learning Objectives", "size": "2xl", "icon": "Target" },
                { "type": "spacer", "h": 10 },
                {
                  "type": "checklist",
                  "items": [
                    { "text": "Distinguish between zero-shot, few-shot, and chain-of-thought prompting strategies", "status": "pending" },
                    { "text": "Construct structured prompts using the CIEC framework", "status": "pending" },
                    { "text": "Evaluate prompt quality by analyzing output relevance, accuracy, and consistency", "status": "pending" },
                    { "text": "Refactor underperforming prompts through systematic iteration and testing", "status": "pending" }
                  ],
                  "showLabels": false
                },
                { "type": "spacer", "h": 12 },
                { "type": "callout", "text": "Prerequisites: Completion of Module 1 (AI Overview) and Module 2 (Language Models). Familiarity with at least one LLM interface (Claude, ChatGPT, etc.).", "icon": "Info", "bg": "#10b98115", "border": "#10b98140" }
              ]
            },
            {
              "title": "Core Concepts",
              "bg": "#0b2019",
              "bgGradient": "linear-gradient(135deg, #0a1f1a 0%, #0f2922 100%)",
              "color": "#d1fae5",
              "accent": "#34d399",
              "padding": "36px 48px",
              "duration": 90,
              "blocks": [
                { "type": "heading", "text": "Core Prompting Strategies", "size": "2xl", "icon": "Lightbulb" },
                { "type": "spacer", "h": 8 },
                {
                  "type": "matrix",
                  "xLeft": "Simple Tasks",
                  "xRight": "Complex Tasks",
                  "yTop": "High Accuracy",
                  "yBottom": "Low Cost",
                  "quadrants": [
                    { "title": "Few-Shot", "icon": "Layers", "color": "#34d399", "items": ["2-5 examples", "+15-30% accuracy"] },
                    { "title": "Chain-of-Thought", "icon": "Link", "color": "#3b82f6", "items": ["Step-by-step reasoning", "Best for multi-step"] },
                    { "title": "Zero-Shot", "icon": "Zap", "color": "#f59e0b", "items": ["No examples needed", "Lowest token cost"] },
                    { "title": "Direct Instruction", "icon": "MessageSquare", "color": "#a78bfa", "items": ["Clear task statement", "Good baseline"] }
                  ]
                },
                { "type": "text", "text": "Key insight: Few-shot prompting improves accuracy by 15-30% on classification tasks, but adds token cost. Choose based on your accuracy-cost tradeoff.", "size": "sm", "color": "#6ee7b7" }
              ]
            },
            {
              "title": "The Framework",
              "bg": "#0d2520",
              "bgGradient": "linear-gradient(135deg, #0a1f1a 0%, #132f26 100%)",
              "color": "#d1fae5",
              "accent": "#10b981",
              "padding": "36px 48px",
              "duration": 90,
              "blocks": [
                { "type": "heading", "text": "The CIEC Framework", "size": "2xl", "icon": "Layout" },
                { "type": "spacer", "h": 8 },
                { "type": "steps", "items": [
                  { "title": "Context", "text": "Define the role, audience, and domain the model should operate in" },
                  { "title": "Instruction", "text": "State the specific task clearly — what output you need and in what format" },
                  { "title": "Examples", "text": "Provide sample inputs and ideal outputs to anchor the model's behavior" },
                  { "title": "Constraints", "text": "Set boundaries: length limits, tone, forbidden topics, output schema" }
                ]},
                { "type": "spacer", "h": 10 },
                {
                  "type": "cycle",
                  "items": [
                    { "label": "Draft", "icon": "✏️" },
                    { "label": "Test", "icon": "▶️" },
                    { "label": "Evaluate", "icon": "📊" },
                    { "label": "Refine", "icon": "🔄" }
                  ],
                  "centerLabel": "CIEC",
                  "centerSub": "iterate"
                }
              ]
            },
            {
              "title": "Practice Exercise",
              "bg": "#0a1f1a",
              "bgGradient": "linear-gradient(160deg, #0a1f1a 0%, #0f2922 100%)",
              "color": "#d1fae5",
              "accent": "#34d399",
              "padding": "36px 48px",
              "duration": 120,
              "blocks": [
                { "type": "heading", "text": "Practice Exercise", "size": "2xl", "icon": "Edit" },
                { "type": "spacer", "h": 6 },
                { "type": "callout", "text": "Write a prompt that asks an LLM to summarize a research paper into a 3-bullet executive brief for a non-technical CEO. Apply all four CIEC steps. Test with at least two different papers and compare outputs.", "icon": "FileQuestion", "bg": "#34d39915", "border": "#34d39940" },
                { "type": "spacer", "h": 8 },
                {
                  "type": "comparison",
                  "items": [
                    { "title": "Weak Prompt", "icon": "AlertTriangle", "color": "#ef4444", "items": ["\"Summarize this paper\"", "\"Make it short\"", "No format specified"] },
                    { "title": "Strong Prompt", "icon": "CheckCircle", "color": "#22c55e", "items": ["\"You are a research analyst for a non-technical exec\"", "\"Exactly 3 bullet points, each under 20 words\"", "\"Markdown list with bold key findings\""] }
                  ],
                  "dividerLabel": "VS"
                },
                { "type": "spacer", "h": 8 },
                { "type": "badge", "text": "Due: Next Session", "icon": "Calendar", "color": "#fbbf24", "bg": "#fbbf2415", "border": "#fbbf2440" }
              ]
            }
          ]
        }
      ]
    }
  ]
}
