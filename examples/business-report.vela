            {
              "title": "Roadmap Progress",
              "bg": "#0f172a",
              "color": "#e2e8f0",
              "accent": "#6366f1",
              "padding": "36px 48px",
              "duration": 60,
              "blocks": [
                { "type": "heading", "text": "Roadmap Progress", "size": "lg" },
                {
